ENV_FOR_DYNACONF=production

# ── IMPORTANT: every MLSS setting must use the `MLSS_` prefix ────────────────
# config.py wires Dynaconf with `envvar_prefix="MLSS"`, so only keys starting
# with `MLSS_` are loaded; the prefix is stripped on read, meaning
# `MLSS_FOO=bar` is accessed as `config.get("FOO")`. Any key in this file
# without the prefix is not read. Keep the prefix on every new key.

# ── Application settings ─────────────────────────────────────────────────────
MLSS_LOG_FILE=data/log.csv
MLSS_LOG_INTERVAL=10
MLSS_DB_FILE=data/sensor_data.db
# Kasa smart-plug LAN IP. Assign a DHCP reservation on your router so the
# address does not drift. This MUST be set — there is no sensible default.
MLSS_FAN_KASA_SMART_PLUG_IP=192.168.1.63

# ── Session secret (required when any auth is enabled) ────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# MLSS_SECRET_KEY=replace-with-a-long-random-string

# ── Option A: GitHub OAuth (recommended for internet-facing deployment) ────────
# 1. Go to https://github.com/settings/developers → OAuth Apps → New OAuth App
# 2. Set Homepage URL to your Pi's address (e.g. https://192.168.1.x:5000)
# 3. Set Callback URL to: https://your-address:5000/auth/callback
# 4. Copy Client ID and generate a Client Secret
# MLSS_GITHUB_CLIENT_ID=your_client_id
# MLSS_GITHUB_CLIENT_SECRET=your_client_secret
# MLSS_ALLOWED_GITHUB_USER=your_github_username   # leave unset to allow any GitHub user

# ── Option B: Local username/password (simpler; good for LAN-only use) ────────
# MLSS_AUTH_USERNAME=admin
# MLSS_AUTH_PASSWORD=changeme

# ── HTTPS / TLS ──────────────────────────────────────────────────────────────
# Enable HTTPS (default: true). Set to "false" to run plain HTTP.
# MLSS_HTTPS_ENABLED=true
# Paths to the TLS certificate and private key (default: certs/cert.pem, certs/key.pem)
# Generate a self-signed cert with: python scripts/generate_certs.py
# MLSS_SSL_CERT_FILE=certs/cert.pem
# MLSS_SSL_KEY_FILE=certs/key.pem
