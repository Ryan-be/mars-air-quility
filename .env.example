ENV_FOR_DYNACONF=production
LOG_FILE=data/log.csv
LOG_INTERVAL=10
DB_FILE=data/sensor_data.db
FAN_KASA_SMART_PLUG_IP=192.168.1.63

# ── Authentication (uncomment to enable login page) ───────────────────────────
