# All vars use the MLSS_ prefix (required by dynaconf config).
# MLSS_AUTH_USERNAME=admin
# MLSS_AUTH_PASSWORD=changeme
# MLSS_SECRET_KEY=replace-with-a-long-random-string   # keeps sessions valid across restarts
