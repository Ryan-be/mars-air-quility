[MASTER]
# Hardware libs that only exist on the Pi — skip import resolution for them
ignored-modules=board,busio,adafruit_ahtx0,adafruit_sgp30,mics6814,kasa,authlib,authlib.integrations,authlib.integrations.flask_client,digitalio,adafruit_rgb_display,adafruit_rgb_display.st7735,scripts

[MESSAGES CONTROL]
disable=
    missing-module-docstring,
    missing-class-docstring,
    missing-function-docstring,
    broad-exception-caught,
    global-statement,
    logging-fstring-interpolation,
    unspecified-encoding,
    invalid-name,
    wrong-import-order,
    wrong-import-position,
    import-outside-toplevel,
    unused-argument,
    consider-using-from-import,
    too-few-public-methods,
    too-many-positional-arguments,
    unbalanced-tuple-unpacking,
    too-many-lines,
    too-many-locals,
    too-many-branches,
    too-many-statements,
    too-many-arguments,
    duplicate-code,
    too-many-instance-attributes,
    too-many-nested-blocks,
    protected-access,
    too-many-return-statements,
    redefined-outer-name,
    contextmanager-generator-missing-cleanup,
    use-implicit-booleaness-not-comparison,
    abstract-class-instantiated,

[FORMAT]
max-line-length=120

[DESIGN]
max-args=8

[TYPECHECK]
# @tee_to_outbox injects `conn` at call-time. Without telling pylint the
# decorator mutates the signature, every caller of an @tee_to_outbox-wrapped
# function trips E1120 "no value for argument" because pylint statically
# resolves the call to the original FunctionDef (which still has `conn` as
# the first parameter). signature-mutators turns off arity checking for
# functions decorated with the listed names.
signature-mutators=tee_to_outbox
